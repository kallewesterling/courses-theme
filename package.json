{
  "scripts": {
    "lint:css": "stylelint \"production/**/*.css\"",
    "lint:css:fix": "stylelint \"production/**/*.css\" --fix",
    "lint:js": "eslint .",
    "lint": "npm run lint:css && npm run lint:js",
    "build:css": "NODE_ENV=production postcss production/style.css -o dist/bundle.min.css",
    "build:css:test": "NODE_ENV=production postcss production/style.css -o test/bundle.min.css",
    "build:css:dev": "postcss production/style.css -o dist/bundle.css --map",
    "build:js": "esbuild production/theme.mjs --bundle --minify --outfile=dist/bundle.min.js",
    "build:js:dev": "esbuild production/theme.mjs --bundle --sourcemap --outfile=dist/bundle.js",
    "watch:css": "postcss production/style.css -o dist/bundle.css --watch --map",
    "watch:js": "esbuild production/theme.mjs --bundle --sourcemap --outfile=dist/bundle.js --watch",
    "build": "npm run lint && npm run build:css && npm run build:js",
    "dev": "npm run watch:css & npm run watch:js",
    "test": "node --test"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "autoprefixer": "^10.4.23",
    "cssnano": "^7.1.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-sorting": "^9.1.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^7.0.1"
  },
  "dependencies": {
    "terser": "^5.44.1"
  }
}
